POSTGRES_PASSWORD=changeme
CM_API_KEY=
CM_LIST_ID=
CT_OUTREACH_API_KEY=change-me-service-token

# OOO reply harvest (Email-list finalisation §1a). editor@theautoexec.com mailbox
# password from 1Password (TAE email accounts). Leave OOO_IMAP_FOLDER blank to
# auto-detect the TAE-RobotReplies folder.
OOO_IMAP_HOST=mail.theautoexec.com
OOO_IMAP_PORT=993
OOO_IMAP_USER=editor@theautoexec.com
OOO_IMAP_PASSWORD=
OOO_IMAP_FOLDER=

# Newspress Australia scrape (Email-list finalisation §1b). The release list is
# behind a Sanctum media login; NEWSPRESS_COOKIE is a logged-in session's Cookie
# header, supplied at runtime via -e (not persisted). Browser UA required.
NEWSPRESS_BASE=https://newspressaustralia.com
NEWSPRESS_COOKIE=
NEWSPRESS_RPS=1.5
